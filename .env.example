# Copiá este archivo a .env y completá los valores.
# Producción (Railway API): AUTH_ENABLED=true, CORS_ORIGINS incluye URL de Vercel.
# Frontend (Vercel): ver frontend/.env.local.example (NEXT_PUBLIC_*).

# --- Auth (Supabase JWT) ---
# Local dev: false. Con true, el API valida JWT (JWKS ES256 + fallback HS256).
AUTH_ENABLED=false
SUPABASE_JWT_SECRET=
# URL del proyecto (para JWKS). También sirve NEXT_PUBLIC_SUPABASE_URL en .env raíz.
# SUPABASE_URL=https://<ref>.supabase.co
# Opcional: solo si la API necesita bypass RLS (no en frontend).
# SUPABASE_SERVICE_ROLE_KEY=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- X / twscrape ---
# Cómo obtener las cookies:
# 1. Iniciá sesión en https://x.com con tu navegador
# 2. Abrí DevTools → Application → Cookies → x.com
# 3. Copiá los valores de auth_token y ct0
X_ACCOUNT_NAME=my_account
X_COOKIES=auth_token=TU_AUTH_TOKEN; ct0=TU_CT0_TOKEN
# Local: accounts.db. Railway Worker (volume /data): /data/accounts.db
ACCOUNTS_DB=accounts.db

# --- Store (Postgres + pgvector) ---
POSTGRES_USER=xscraper
POSTGRES_PASSWORD=xscraper
POSTGRES_DB=xscraper
# 5433 en el host para no chocar con un Postgres local en 5432
POSTGRES_PORT=5433
# URL de conexión usada por backend + worker
# Local (Perfil 1): localhost:5433
# Supabase API (Perfil 2): Transaction pooler :6543 — NO uses db.<ref>.supabase.co (IPv6)
DATABASE_URL=postgresql://xscraper:xscraper@localhost:5433/xscraper
# Supabase ejemplo (reemplazá [YOUR-PASSWORD]):
# DATABASE_URL=postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# Backfill embeddings per ingest cycle (Worker). Higher = fewer Signals sin vector.
EMBEDDING_BACKFILL_LIMIT=200

# --- Market Data (Finnhub + fallback Alpha Vantage) ---
FINNHUB_API_KEY=
# Fallback si Finnhub falla (GLOBAL_QUOTE). Comparte cuota con AV news ingest.
ALPHA_VANTAGE_API_KEY=
# Quote Strip y get_quotes usan tickers dinámicos del Corpus (sin WATCHLIST).
# WATCHLIST=  # obsoleto — ignorado si está presente
# Cache de quotes (segundos). Finnhub free: 60 req/min → default 15 min.
QUOTE_CACHE_TTL_SECONDS=900
# Solo aplica al fallback Alpha Vantage (25 req/día free tier).
QUOTE_MAX_DAILY_REQUESTS=25

# --- News Sources ---
# Marketaux: 100 req/día free, 3 artículos por request (MARKETAUX_LIMIT_PER_REQUEST).
MARKETAUX_API_KEY=
MARKETAUX_LIMIT_PER_REQUEST=3
# RSS feeds (sin API key). false para deshabilitar.
RSS_NEWS_ENABLED=true
# Feeds de medios argentinos (Ámbito, La Nación, Infobae, Google News AR).
RSS_AR_FEEDS_ENABLED=true

# --- Article Enrichment (trafilatura) ---
# Extrae Article Body desde canonical_url en Signals de noticias (best-effort).
ARTICLE_BODY_ENABLED=true
ARTICLE_BODY_MAX_PER_INGEST=50
ARTICLE_BODY_MIN_CHARS=200
ARTICLE_BODY_FETCH_DELAY=0.5

# --- Relevance Score (LLM) ---
# Puntaje 0-1 en Ingestion; el Feed ordena por score y oculta bajo umbral.
RELEVANCE_SCORE_ENABLED=true
RELEVANCE_SCORE_MODEL=gpt-4o-mini
RELEVANCE_SCORE_MAX_PER_INGEST=20
RELEVANCE_SCORE_MIN=0.35
RELEVANCE_SCORE_DELAY=0.2

# --- Chat Session (historial Research Chat) ---
# UUID del Operator en dev sin auth (Supabase/local). Con login, usa JWT sub.
LOCAL_OPERATOR_ID=00000000-0000-0000-0000-000000000001

# --- Research Agent (LangGraph, F18) ---
# legacy = loop OpenAI actual; langgraph = ReAct con 7 tools + memoria de sesión
RESEARCH_ENGINE=legacy
RESEARCH_MODEL=gpt-4o-mini
SYNTHESIS_MODEL=gpt-4o-mini
RESEARCH_MAX_TURNS=8
# Mensajes user+assistant previos que ve el agente (default 20)
CHAT_HISTORY_MAX_MESSAGES=20
# LangSmith (opt-in): LANGCHAIN_TRACING_V2=true + LANGSMITH_API_KEY

# --- Story Cluster ---
STORY_CLUSTER_ENABLED=true
STORY_CLUSTER_SIMILARITY=0.88
STORY_CLUSTER_LOOKBACK_HOURS=168

# --- Signal Feed Filter ---
# Modos: relevant (default) | cashtag | strict | off
# relevant: noticias pasan; X solo si $TICKER o cuenta trusted + keyword/link
# cashtag = solo tweets con $TICKER
# strict = igual que relevant para X (legacy)
# off = sin filtro de relevancia (blocklist sigue activa)
SIGNAL_FILTER=relevant
# Búsqueda global en X (trae ruido). false = solo timelines de FINANCIAL_ACCOUNTS.
X_INCLUDE_SEARCH=false

# --- X Complement (secundario: corre después de News Sources; mismo volumen que antes) ---
X_COMPLEMENT_ENABLED=true
# Opcional: tope de cuentas (vacío = todas FINANCIAL_ACCOUNTS)
# X_COMPLEMENT_MAX_ACCOUNTS=
# Temas humanitarios/geopolíticos sin ángulo de mercado (aplica a todas las fuentes).
# SIGNAL_TOPIC_BLOCKLIST=conflict is driving,WFP,civilians were killed,...
# SIGNAL_KEYWORDS=stock,market,earnings,...  (default extenso en scraper/filters.py)
# SIGNAL_BLOCKLIST=giveaway,airdrop,...      (default en scraper/filters.py)
# SIGNAL_TRUSTED_SOURCES=Reuters,Bloomberg,WSJ,FT,CNBC,business,ecb,federalreserve
SIGNAL_MIN_LIKES=0
SIGNAL_REQUIRE_LINK=false

# --- Retention Window ---
RETENTION_DAYS=60
